rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Match the specific guest user path that is failing
    match /users/guest_user_free_mode {
      allow read, write: if true; // Allows guests in free mode to update their state
    }

    // Your existing rules for standard users
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Allow access to subcollections for standard users
      match /{allSubcollections=**} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
  }
}
