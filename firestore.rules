rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Catch-all default deny to enforce secure-by-default access
    match /{document=**} {
      allow read, write: if false;
    }

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return (isSignedIn() && request.auth.uid == userId) || (userId == "guest_user_free_mode");
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Allow users to read/write their own user document
    match /users/{userId} {
      allow read, create, update: if request.auth != null && request.auth.uid == userId;
      allow read, write: if userId == "guest_user_free_mode";

      // --- Certificates Subcollection inside User ---
      match /certificates/{certId} {
        allow read, write: if isOwner(userId);
      }

      // --- Enrollments Subcollection ---
      match /enrollments/{courseId} {
        allow read, write: if isOwner(userId);
      }

      // --- Snapshots Subcollection ---
      match /snapshots/{snapshotId} {
        allow read, write: if isOwner(userId);
      }

      // --- Stripe Checkout Sessions Subcollection ---
      match /checkout_sessions/{sessionId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Allow users to read their own subscription data status
    match /subscriptions/{subscriptionId} {
      allow read: if request.auth != null && resource.data.userId == request.auth.uid;
      allow write: if false; // Only allow backend/Stripe webhooks to update subscriptions
    }

    // --- Global Certificates (Legacy/Fallback mapping) ---
    match /certificates/{certificateId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.token.admin == true;
    }

    // --- Nodes Collection ---
    match /nodes/{nodeId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- Connection Verification / Connection test collection ---
    match /test/{testId} {
      allow read: if true;
      allow write: if false;
    }
  }
}
