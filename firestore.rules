rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- GLOBAL HELPERS ---
    function isValidId(id) { 
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); 
    }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'phidephefem@gmail.com' ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ); 
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      function isValidUser(data) {
        return data.keys().hasAll(['uid', 'name', 'email']) &&
               data.uid == userId &&
               data.name is string && data.name.size() <= 100 &&
               data.name.size() > 0 &&
               data.email is string && data.email.size() <= 100;
      }

      // Allow searching for a user by email (for login/signup check)
      allow list: if true; 
      
      // Allow getting a specific user profile
      allow get: if isOwner(userId) || isAdmin();

      // Allow creating a new user profile
      allow create: if isOwner(userId) && isValidUser(incoming());

      // Allow updating own profile or admin modification
      allow update: if (isOwner(userId) || isAdmin()) && isValidUser(incoming()) && (
        isAdmin() || (
          // Action: Update Profile Info
          incoming().diff(existing()).affectedKeys().hasOnly(['name', 'phone', 'country', 'linkedin'])
        )
      );
      
      // Subcollections (enrollments, certificates)
      match /enrollments/{courseId} {
        function isValidEnrollment(data) {
          return data.keys().hasAll(['userId', 'courseId']) &&
                 data.userId == userId &&
                 data.courseId == courseId;
        }

        allow read: if isOwner(userId) || isAdmin();
        allow create: if isOwner(userId) && isValidEnrollment(incoming());
        allow update: if (isOwner(userId) || isAdmin()) && isValidEnrollment(incoming()) && (
          isAdmin() || (
            // Action: Update Progress
            incoming().diff(existing()).affectedKeys().hasOnly(['status', 'progress', 'completedModules'])
          )
        );
        allow delete: if isAdmin();
      }

      match /certificates/{certId} {
        allow read: if isOwner(userId) || isAdmin();
        // Usually system/admin issues these, but for this demo owner can create after completion
        allow create: if isOwner(userId) || isAdmin();
        allow update, delete: if isAdmin();
      }
    }

    // --- ADMINS COLLECTION ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Managed out-of-band
    }
  }
}
